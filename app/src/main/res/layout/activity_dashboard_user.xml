<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Konten Utama -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#F1F8F4">

        <!-- Toolbar -->
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@drawable/bg_header"
            app:title="EcoSnap"
            app:titleTextColor="#FFFFFF"/>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Welcome Banner -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_header"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Selamat Datang 👋"
                        android:textColor="#C8E6C9"
                        android:textSize="13sp"/>

                    <TextView
                        android:id="@+id/tvNamaUser"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="User"
                        android:textColor="#FFFFFF"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:layout_marginTop="4dp"/>

                    <TextView
                        android:id="@+id/tvWilayahUser"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="RT 01 - RW 01"
                        android:textColor="#C8E6C9"
                        android:textSize="12sp"
                        android:layout_marginTop="2dp"/>

                    <!-- Tombol Scan di Banner -->
                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btnScanCepat"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📷  Scan Sampah Sekarang"
                        android:backgroundTint="#FFFFFF"
                        android:textColor="#2E7D32"
                        android:textStyle="bold"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"
                        android:layout_marginTop="16dp"/>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Statistik Hari Ini -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Aktivitas Hari Ini"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#1B5E20"
                        android:layout_marginBottom="10dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="16dp">

                        <!-- Scan Hari Ini -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="@drawable/bg_card_white"
                            android:orientation="vertical"
                            android:padding="16dp"
                            android:layout_marginEnd="6dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="📊 Scan Hari Ini"
                                android:textColor="#2E7D32"
                                android:textSize="12sp"/>
                            <TextView
                                android:id="@+id/tvScanHariIni"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="#1B5E20"
                                android:textSize="32sp"
                                android:textStyle="bold"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="item"
                                android:textColor="#81C784"
                                android:textSize="11sp"/>
                        </LinearLayout>

                        <!-- Scan Minggu Ini -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="@drawable/bg_card_white"
                            android:orientation="vertical"
                            android:padding="16dp"
                            android:layout_marginStart="6dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="📅 Minggu Ini"
                                android:textColor="#2E7D32"
                                android:textSize="12sp"/>
                            <TextView
                                android:id="@+id/tvScanMingguIni"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="#1B5E20"
                                android:textSize="32sp"
                                android:textStyle="bold"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="item"
                                android:textColor="#81C784"
                                android:textSize="11sp"/>
                        </LinearLayout>

                    </LinearLayout>

                    <!-- Scan Terakhir -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Scan Terakhir"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#1B5E20"
                        android:layout_marginBottom="10dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_card_white"
                        android:orientation="horizontal"
                        android:padding="16dp"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <LinearLayout
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_card_green_dark"
                            android:gravity="center">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="♻️"
                                android:textSize="20sp"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="12dp">
                            <TextView
                                android:id="@+id/tvJenisTerakhir"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Belum ada scan"
                                android:textColor="#1B5E20"
                                android:textSize="15sp"
                                android:textStyle="bold"/>
                            <TextView
                                android:id="@+id/tvKategoriTerakhir"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="-"
                                android:textColor="#81C784"
                                android:textSize="12sp"/>
                            <TextView
                                android:id="@+id/tvWaktuTerakhir"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="-"
                                android:textColor="#BDBDBD"
                                android:textSize="11sp"/>
                        </LinearLayout>

                    </LinearLayout>

                    <!-- Quote Harian -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tips Hari Ini 🌱"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#1B5E20"
                        android:layout_marginBottom="10dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_card_green_dark"
                        android:orientation="vertical"
                        android:padding="20dp"
                        android:layout_marginBottom="16dp">

                        <TextView
                            android:id="@+id/tvQuote"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Memilah sampah hari ini, menyelamatkan bumi untuk generasi berikutnya 🌍"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp"
                            android:lineSpacingExtra="4dp"/>

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>
        </ScrollView>

    </LinearLayout>

    <!-- Sidebar -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigationView"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        app:headerLayout="@layout/nav_header"
        app:menu="@menu/nav_menu"
        app:itemTextColor="#1B5E20"
        app:itemIconTint="#2E7D32"
        app:itemBackground="@drawable/bg_nav_item"/>

</androidx.drawerlayout.widget.DrawerLayout>