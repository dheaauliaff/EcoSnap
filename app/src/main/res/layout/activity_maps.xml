<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen_soft"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Peta Sebaran"
                android:textColor="#0D2F16"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:background="@drawable/bg_modern_card"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:text="Filter"
                android:textColor="#1B5E20"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="390dp"
            android:layout_marginTop="18dp"
            app:cardCornerRadius="22dp"
            app:cardElevation="5dp"
            app:strokeColor="#E0EFE2"
            app:strokeWidth="1dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_map_mock"
                android:padding="22dp">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="2dp"
                    android:layout_gravity="center"
                    android:background="#D4E3D7"
                    android:rotation="18" />

                <View
                    android:layout_width="2dp"
                    android:layout_height="match_parent"
                    android:layout_gravity="center"
                    android:background="#D4E3D7"
                    android:rotation="26" />

                <TextView
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:layout_gravity="top|center_horizontal"
                    android:layout_marginTop="42dp"
                    android:background="@drawable/bg_green_circle"
                    android:elevation="6dp"
                    android:gravity="center"
                    android:text="12"
                    android:textColor="#1B5E20"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="70dp"
                    android:layout_height="70dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_blue_circle"
                    android:elevation="6dp"
                    android:gravity="center"
                    android:text="18"
                    android:textColor="#2E88D4"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="58dp"
                    android:layout_height="58dp"
                    android:layout_gravity="bottom|end"
                    android:layout_marginEnd="28dp"
                    android:layout_marginBottom="74dp"
                    android:background="@drawable/bg_orange_circle"
                    android:elevation="6dp"
                    android:gravity="center"
                    android:text="7"
                    android:textColor="#FB8C00"
                    android:textSize="19sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="54dp"
                    android:layout_height="54dp"
                    android:layout_gravity="bottom|start"
                    android:layout_marginStart="52dp"
                    android:layout_marginBottom="92dp"
                    android:background="@drawable/bg_red_circle"
                    android:elevation="6dp"
                    android:gravity="center"
                    android:text="3"
                    android:textColor="#E53935"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </FrameLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="3dp"
            app:strokeColor="#E6F1E7"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Produksi Terbanyak"
                    android:textColor="#0D2F16"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Anorganik (Plastik)    18 scan"
                    android:textColor="#0D2F16"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="Recycle (Kardus)       16 scan"
                    android:textColor="#0D2F16"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="Organik                12 scan"
                    android:textColor="#0D2F16"
                    android:textSize="14sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</ScrollView>
