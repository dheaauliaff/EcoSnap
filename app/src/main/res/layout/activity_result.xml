<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F1F8F4">

    <FrameLayout
        android:id="@+id/imageContainer"
        android:layout_width="0dp"
        android:layout_height="320dp"
        android:layout_margin="16dp"
        android:background="@drawable/bg_card_white"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/imgHasil"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:background="@android:color/black"/>

        <com.example.ecosnap.OverlayView
            android:id="@+id/overlayView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>
    </FrameLayout>

    <LinearLayout
        android:id="@+id/cardInfo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="@drawable/bg_card_white"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintTop_toBottomOf="@id/imageContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvNamaSampah"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nama sampah"
            android:textStyle="bold"
            android:textSize="20sp"
            android:textColor="#1B5E20" />

        <TextView
            android:id="@+id/tvKategori"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Kategori"
            android:textSize="14sp"
            android:textColor="#2E7D32"
            android:layout_marginTop="8dp"/>

        <TextView
            android:id="@+id/tvSaran"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Saran pembuangan"
            android:textSize="14sp"
            android:textColor="#4E5D52"
            android:layout_marginTop="8dp"/>

        <TextView
            android:id="@+id/tvFunfact"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Fun fact"
            android:textSize="14sp"
            android:textColor="#4E5D52"
            android:layout_marginTop="8dp"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>