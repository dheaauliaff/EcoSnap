<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F1F8F4">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_header"
            android:orientation="vertical"
            android:padding="24dp"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🌿 EcoSnap Dashboard"
                android:textColor="#FFFFFF"
                android:textSize="13sp"/>

            <TextView
                android:id="@+id/tvNamaAdmin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Admin"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:textStyle="bold"
                android:layout_marginTop="4dp"/>

            <TextView
                android:id="@+id/tvWilayahAdmin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="RW 01"
                android:textColor="#C8E6C9"
                android:textSize="13sp"
                android:layout_marginTop="2dp"/>

        </LinearLayout>

        <!-- Statistik Cards -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Statistik Sampah"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#1B5E20"
            android:layout_marginBottom="10dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_card_green_dark"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginEnd="6dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total Temuan"
                    android:textColor="#C8E6C9"
                    android:textSize="11sp"/>
                <TextView
                    android:id="@+id/tvTotalSampah"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#FFFFFF"
                    android:textSize="32sp"
                    android:textStyle="bold"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="item"
                    android:textColor="#C8E6C9"
                    android:textSize="11sp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_card_green_medium"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginStart="6dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Organik"
                    android:textColor="#C8E6C9"
                    android:textSize="11sp"/>
                <TextView
                    android:id="@+id/tvTotalOrganik"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#FFFFFF"
                    android:textSize="32sp"
                    android:textStyle="bold"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="item"
                    android:textColor="#C8E6C9"
                    android:textSize="11sp"/>
            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_card_green_light"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginEnd="6dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Anorganik"
                    android:textColor="#C8E6C9"
                    android:textSize="11sp"/>
                <TextView
                    android:id="@+id/tvTotalAnorganik"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#FFFFFF"
                    android:textSize="32sp"
                    android:textStyle="bold"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="item"
                    android:textColor="#C8E6C9"
                    android:textSize="11sp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_card_green_pale"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginStart="6dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bukan Sampah"
                    android:textColor="#C8E6C9"
                    android:textSize="11sp"/>
                <TextView
                    android:id="@+id/tvTotalBukanSampah"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#FFFFFF"
                    android:textSize="32sp"
                    android:textStyle="bold"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="item"
                    android:textColor="#C8E6C9"
                    android:textSize="11sp"/>
            </LinearLayout>

        </LinearLayout>

        <!-- Grafik -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Grafik Jenis Sampah"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#1B5E20"
            android:layout_marginBottom="10dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card_white"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="20dp">

            <com.github.mikephil.charting.charts.BarChart
                android:id="@+id/barChart"
                android:layout_width="match_parent"
                android:layout_height="220dp"/>

        </LinearLayout>

        <!-- Ranking RT -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🏆 Ranking RT Terbanyak"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#1B5E20"
            android:layout_marginBottom="10dp"/>

        <LinearLayout
            android:id="@+id/layoutRanking"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card_white"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="16dp"/>

    </LinearLayout>
</ScrollView>